# Local defaults
PORT=4242
NODE_ENV=development
PUBLIC_BASE_URL=http://localhost:4242
TRUST_PROXY=false

# Stripe
# Use sk_test_... locally and sk_live_... in production.
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_ALLOWED_COUNTRIES=NL,BE,DE

# PostgreSQL / Supabase
# Required in production. Local development can omit DATABASE_URL to use the file fallback.
# DATABASE_URL=postgresql://user:password@host:5432/mallow
DATABASE_SSL=require

# Optional: enables GET /api/admin/orders with Authorization: Bearer <token>.
# ADMIN_TOKEN=replace_with_a_long_random_value
